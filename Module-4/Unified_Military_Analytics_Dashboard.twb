            <column caption='Submarines' datatype='integer' name='[submarines]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1043460982669313]' derivation='Sum' name='[sum:Calculation_1043460982669313:qk]' pivot='key' type='quantitative' />
            <column caption='Tanks' datatype='integer' name='[tanks]' role='measure' type='quantitative' />

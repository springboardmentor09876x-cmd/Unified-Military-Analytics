            <column caption='Total Military Assests' datatype='integer' name='[Calculation_1043460982669313]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN([tanks]) +&#13;&#10;ZN([total_military_aircraft]) +&#13;&#10;ZN([destroyers]) +&#13;&#10;ZN([frigates]) +&#13;&#10;ZN([corvettes]) +&#13;&#10;ZN([submarines]) +&#13;&#10;ZN([aircraft_carriers]) +&#13;&#10;ZN([helicopter_carriers])' />
